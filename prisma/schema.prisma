generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Nomina
model Payroll {           
  id            Int      @id @default(autoincrement())
  date          DateTime
  week          Int
  amountReceived Float
  isr           Float
  notes         String?
  createdAt     DateTime @default(now())
}

//GastoFijo
model FixedExpense {
  id           Int           @id @default(autoincrement())
  name         String
  cost         Float
  dueDay       Int
  payments     FixedPayment[]
  createdAt    DateTime      @default(now())
}

// PagoFijo
model FixedPayment {
  id             Int          @id @default(autoincrement())
  fixedExpense   FixedExpense @relation(fields: [fixedExpenseId], references: [id])
  fixedExpenseId Int
  date           DateTime
  paid           Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// GastoVariable
model VariableExpense {
  id          Int      @id @default(autoincrement())
  description String
  date        DateTime
  amount      Float
  createdAt   DateTime @default(now())
}